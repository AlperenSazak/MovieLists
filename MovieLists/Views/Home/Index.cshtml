                 async function addToLibrary(event) {
            event.preventDefault();

            // 🔥 KONTROL: selectedMovie var mı?
            if (!selectedMovie || !selectedMovie.id) {
                showToast('Film bilgisi bulunamadı!', 'error');
                console.error('selectedMovie is null or missing id:', selectedMovie);
                return;
            }

            let genres = '';
            try {
                const detailResponse = await fetch(API_URL + '/Tmdb/' + selectedMovie.id);
                const movieDetail = await detailResponse.json();
                if (movieDetail.genres && movieDetail.genres.length > 0) {
                    genres = movieDetail.genres.map(g => g.name).join(',');
                }
            } catch (error) {
                console.error('Genre alınamadı:', error);
            }

            const movieData = {
                tmdbId: selectedMovie.id,
                title: selectedMovie.title,
                originalTitle: selectedMovie.original_Title,
                overview: selectedMovie.overview,
                posterPath: selectedMovie.poster_Path,
                backdropPath: selectedMovie.backdrop_Path,
                releaseDate: selectedMovie.release_Date || null,
                voteAverage: selectedMovie.vote_Average,
                runtime: selectedMovie.runtime,
                watchedDate: document.getElementById('watchedDate').value,
                userRating: parseInt(document.getElementById('userRating').value),
                userNotes: document.getElementById('userNotes').value,
                genres: genres
            };

            try {
                const response = await fetch(API_URL + '/Movies', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify(movieData)
                });

                if (response.ok) {
                    const tmdbIdToDelete = selectedMovie.id; 

                    showToast('Film kütüphanene eklendi!', 'success');
                    closeModal();
                    document.getElementById('userRating').value = 8;
                    document.getElementById('userNotes').value = '';

                    // 🔥 Daha Sonra İzle'den sil
                    try {
                        const watchLaterResponse = await fetch(API_URL + '/WatchLater', {
                            headers: { 'Authorization': 'Bearer ' + token }
                        });

                        if (watchLaterResponse.ok) {
                            const watchLaterMovies = await watchLaterResponse.json();
                            const movieToDelete = watchLaterMovies.find(m => m.tmdbId === tmdbIdToDelete);

                            if (movieToDelete) {
                                await fetch(API_URL + '/WatchLater/' + movieToDelete.id, {
                                    method: 'DELETE',
                                    headers: { 'Authorization': 'Bearer ' + token }
                                });
                                console.log('✅ Daha Sonra İzle listesinden kaldırıldı');
                            }
                        }
                    } catch (error) {
                        console.log('Daha Sonra İzle temizleme hatası:', error);
                    }

                    const activeSection = document.querySelector('.content-section.active');
                    if (activeSection && activeSection.id === 'watchLaterSection') {
                        setTimeout(() => {
                            window.location.reload();
                        }, 1000);
                    }
                }
                else if (response.status === 400) {
                    const errorText = await response.text();
                    showToast(errorText, 'warning');
                    closeModal();
                }
                else if (response.status === 401) {
                    showToast('Oturumun sona erdi!', 'error');
                    setTimeout(() => {
                        localStorage.removeItem('token');
                        window.location.assign('/Account/Login');
                    }, 1500);
                }
                else {
                    showToast('Film eklenirken hata oluştu!', 'error');
                }
            } catch (error) {
                showToast('Bağlantı hatası!', 'error');
                console.error(error);
            }
        }


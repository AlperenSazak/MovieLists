                function createMovieCard(movie, cardType) {
            const posterUrl = (movie.poster_Path || movie.posterPath) ? 'https://image.tmdb.org/t/p/w500' + (movie.poster_Path || movie.posterPath) : '';
            const year = ((movie.release_Date || movie.releaseDate || '').split('-')[0]) || 'N/A';
            const rating = (movie.vote_Average || movie.voteAverage || 0).toFixed(1);
            const title = movie.title || 'Başlık Yok';
            const movieId = movie.id || movie.tmdbId;
            const tmdbId = movie.tmdbId || movie.id;

            console.log('createMovieCard - tmdbId:', tmdbId, 'movie:', movie);

            if (cardType === 'search') movieCache[movieId] = movie;

            const cardClick = tmdbId ? `data-tmdb-id="${tmdbId}"` : '';

            let actionButtons = '';
            if (cardType === 'search') {
                actionButtons = `
                    <button class="add-btn" data-action="add" data-movie-id="${movieId}">➕ Kütüphaneye Ekle</button>
                    <button class="watchlater-btn" data-action="watchlater" data-movie-id="${movieId}">⏰ Daha Sonra İzle</button>
                `;
            } else if (cardType === 'watchlater') {
                actionButtons = `
                    <button class="add-btn" data-action="move" data-movie-id="${movie.id}" data-tmdb-id="${tmdbId}">➕ Kütüphaneye Ekle</button>
                    <button class="delete-btn" data-action="delete-watch" data-movie-id="${movie.id}">🗑️ Sil</button>
                `;
            } else if (cardType === 'library') {
                actionButtons = `<button class="delete-btn" data-action="delete" data-movie-id="${movie.id}">🗑️ Sil</button>`;
            }

            return `<div class="movie-card" ${cardClick} style="cursor: pointer;">` +
                (posterUrl ? '<img src="' + posterUrl + '" alt="' + title + '" class="movie-poster">' : '<div class="movie-poster"></div>') +
                '<div class="movie-info"><div class="movie-title">' + title + '</div><div class="movie-year">📅 ' + year +
                '</div><span class="movie-rating">⭐ ' + rating + '</span>' + actionButtons + '</div></div>';
        }


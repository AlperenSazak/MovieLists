@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MovieLists - Giriş Yap</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            overflow: hidden;
            position: relative;
        }

            body::before {
                content: '';
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px);
                background-size: 50px 50px;
                animation: moveBackground 20s linear infinite;
                z-index: 0;
            }

        @@keyframes moveBackground {
            0% {
                transform: translate(0, 0);
            }

            100% {
                transform: translate(50px, 50px);
            }
        }

        .container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
            animation: fadeInDown 0.8s ease;
        }

            .logo h1 {
                font-size: 3.5em;
                font-weight: 800;
                text-shadow: 0 8px 30px rgba(0,0,0,0.3);
                margin-bottom: 10px;
            }

            .logo p {
                font-size: 1.2em;
                opacity: 0.9;
            }

        .auth-container {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(20px);
            border-radius: 25px;
            padding: 45px 40px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: fadeInUp 0.8s ease;
        }

        @@keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 35px;
        }

        .tab {
            flex: 1;
            padding: 15px;
            background: rgba(255,255,255,0.1);
            border: 2px solid transparent;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            font-size: 1.1em;
            text-align: center;
        }

            .tab.active {
                background: rgba(255,255,255,0.25);
                border-color: rgba(255,255,255,0.4);
                box-shadow: 0 5px 20px rgba(0,0,0,0.2);
                transform: translateY(-2px);
            }

        .form-section {
            display: none;
        }

            .form-section.active {
                display: block;
                animation: fadeIn 0.5s ease;
            }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .form-group {
            margin-bottom: 25px;
        }

            .form-group label {
                display: block;
                margin-bottom: 10px;
                font-weight: 600;
                font-size: 0.95em;
                text-shadow: 0 2px 4px rgba(0,0,0,0.2);
            }

        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2em;
            opacity: 0.7;
        }

        input {
            width: 100%;
            padding: 18px 20px 18px 55px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 15px;
            font-size: 16px;
            background: rgba(255,255,255,0.9);
            transition: all 0.3s;
            color: #333;
        }

            input:focus {
                outline: none;
                border-color: rgba(255,255,255,0.5);
                background: rgba(255,255,255,1);
                box-shadow: 0 5px 20px rgba(0,0,0,0.15);
                transform: translateY(-2px);
            }

            input::placeholder {
                color: #999;
            }

        button {
            width: 100%;
            padding: 18px;
            border: none;
            border-radius: 15px;
            font-size: 1.1em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            box-shadow: 0 8px 25px rgba(0,0,0,0.25);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

            button:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 35px rgba(0,0,0,0.35);
            }

            button:active {
                transform: translateY(-1px);
            }

            button:disabled {
                opacity: 0.6;
                cursor: not-allowed;
                transform: none;
            }

        .message {
            margin-top: 20px;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
            font-weight: 600;
            animation: slideIn 0.3s ease;
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.success {
            background: rgba(76, 175, 80, 0.3);
            border: 2px solid rgba(76, 175, 80, 0.6);
        }

        .message.error {
            background: rgba(244, 67, 54, 0.3);
            border: 2px solid rgba(244, 67, 54, 0.6);
        }

        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 0.8s linear infinite;
            margin-right: 10px;
            vertical-align: middle;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @@media (max-width: 768px) {
            .logo h1 {
                font-size: 2.5em;
            }

            .auth-container {
                padding: 35px 25px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <h1>🎬 MovieLists</h1>
            <p>Film Kütüphanene Hoş Geldin</p>
        </div>
        <div class="auth-container">
            <div class="tabs">
                <div class="tab active" onclick="switchAuthTab('login')">Giriş Yap</div>
                <div class="tab" onclick="switchAuthTab('register')">Kayıt Ol</div>
            </div>
            <div id="loginForm" class="form-section active">
                <form onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label>📧 Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">📧</span>
                            <input type="email" id="loginEmail" placeholder="ornek@email.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>🔒 Şifre</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="loginPassword" placeholder="••••••••" required>
                        </div>
                    </div>
                    <button type="submit" id="loginBtn">
                        <span id="loginBtnText">Giriş Yap</span>
                    </button>
                </form>
                <div id="loginMessage"></div>
            </div>
            <div id="registerForm" class="form-section">
                <form onsubmit="handleRegister(event)">
                    <div class="form-group">
                        <label>👤 Kullanıcı Adı</label>
                        <div class="input-wrapper">
                            <span class="input-icon">👤</span>
                            <input type="text" id="registerUsername" placeholder="kullaniciadi" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>📧 Email</label>
                        <div class="input-wrapper">
                            <span class="input-icon">📧</span>
                            <input type="email" id="registerEmail" placeholder="ornek@email.com" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>🔒 Şifre</label>
                        <div class="input-wrapper">
                            <span class="input-icon">🔒</span>
                            <input type="password" id="registerPassword" placeholder="••••••••" required minlength="6">
                        </div>
                    </div>
                    <button type="submit" id="registerBtn">
                        <span id="registerBtnText">Kayıt Ol</span>
                    </button>
                </form>
                <div id="registerMessage"></div>
            </div>
        </div>
    </div>
    <script>
        const API_URL = 'https://localhost:7293/api';

        function switchAuthTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.form-section').forEach(s => s.classList.remove('active'));
            event.target.classList.add('active');
            document.getElementById(tab === 'login' ? 'loginForm' : 'registerForm').classList.add('active');
            document.getElementById('loginMessage').innerHTML = '';
            document.getElementById('registerMessage').innerHTML = '';
        }

        async function handleLogin(event) {
            event.preventDefault();
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const btn = document.getElementById('loginBtn');
            const btnText = document.getElementById('loginBtnText');
            const messageDiv = document.getElementById('loginMessage');

            btn.disabled = true;
            btnText.innerHTML = '<span class="loading"></span>Giriş yapılıyor...';
            messageDiv.innerHTML = '';

            try {
                const response = await fetch(API_URL + '/Auth/login', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({email, password})
                });

                const data = await response.json();

                if (response.ok) {
                    localStorage.setItem('token', data.token);
                    messageDiv.innerHTML = '<div class="message success">✅ ' + data.message + ' Yönlendiriliyorsunuz...</div>';
                    setTimeout(() => {
                        window.location.assign('/');
                    }, 1500);
                } else {
                    messageDiv.innerHTML = '<div class="message error">❌ ' + data.message + '</div>';
                    btn.disabled = false;
                    btnText.textContent = 'Giriş Yap';
                }
            } catch (error) {
                messageDiv.innerHTML = '<div class="message error">❌ Bağlantı hatası!</div>';
                btn.disabled = false;
                btnText.textContent = 'Giriş Yap';
                console.error(error);
            }
        }

        async function handleRegister(event) {
            event.preventDefault();
            const username = document.getElementById('registerUsername').value;
            const email = document.getElementById('registerEmail').value;
            const password = document.getElementById('registerPassword').value;
            const btn = document.getElementById('registerBtn');
            const btnText = document.getElementById('registerBtnText');
            const messageDiv = document.getElementById('registerMessage');

            btn.disabled = true;
            btnText.innerHTML = '<span class="loading"></span>Kayıt yapılıyor...';
            messageDiv.innerHTML = '';

            try {
                const response = await fetch(API_URL + '/Auth/register', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({username, email, password})
                });

                const data = await response.json();

                if (response.ok) {
                    localStorage.setItem('token', data.token);
                    messageDiv.innerHTML = '<div class="message success">✅ ' + data.message + ' Yönlendiriliyorsunuz...</div>';
                    setTimeout(() => {
                        window.location.assign('/');
                    }, 1500);
                } else {
                    messageDiv.innerHTML = '<div class="message error">❌ ' + data.message + '</div>';
                    btn.disabled = false;
                    btnText.textContent = 'Kayıt Ol';
                }
            } catch (error) {
                messageDiv.innerHTML = '<div class="message error">❌ Bağlantı hatası!</div>';
                btn.disabled = false;
                btnText.textContent = 'Kayıt Ol';
                console.error(error);
            }
        }

    </script>
</body>
</html>